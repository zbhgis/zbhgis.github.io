ub Blog**: [https://zbhgis.github.io](https://zbhgis.github.io)\n- **CN Blog**: [https://www.cnblogs.com/zbhgis](https://www.cnblogs.com/zbhgis)\n- **Email**: zbhgisrs@gmail.com\n\u3002", "top": 0, "createdAt": 1750998547, "style": "", "script": "<script src='https://cdn.jsdelivr.net/gh/zbhgis/BlogTheme@0.0.2/static/plugins/GmeekArticleTOC.js'><script src='https://cdn.jsdelivr.net/gh/zbhgis/BlogTheme@0.0.2/static/plugins/GmeekLightbox.js'></script><script>document.querySelectorAll('a').forEach(anchor => {const img = anchor.querySelector('img');if (img && img.hasAttribute('data-canonical-src')) {const canonicalSrc = img.getAttribute('data-canonical-src');anchor.setAttribute('href', canonicalSrc);img.setAttribute('src', canonicalSrc);img.removeAttribute('data-canonical-src');}});</script>", "head": "", "ogImage": "https://avatars.githubusercontent.com/u/116264372?s=400&u=0c4073b50ae732450cd91f380769ba6710d6ce53&v=4", "createdDate": "2025-06-27", "dateLabelColor": "#0969da"}}, "labelColorDict": {"about": "#b60205", "Arcpy": "#e4e669", "Conda": "#6f8d7b", "Data": "#cfd3d7", "ENVI": "#008672", "GEE": "#a2eeef", "Java": "#387044", "link": "#b60205", "MATLAB": "#d73a4a", "Mixed": "#eba87a", "Python": "#0075ca", "RS": "#b4c408", "SNAP": "#7057ff", "Tools": "#d876e3"}, "displayTitle": "zbhgis", "faviconUrl": "https://avatars.githubusercontent.com/u/116264372?s=400&u=0c4073b50ae732450cd91f380769ba6710d6ce53&v=4", "ogImage": "https://avatars.githubusercontent.com/u/116264372?s=400&u=0c4073b50ae732450cd91f380769ba6710d6ce53&v=4", "primerCSS": "<link href='https://mirrors.sustech.edu.cn/cdnjs/ajax/libs/Primer/21.0.7/primer.css' rel='stylesheet' />", "homeUrl": "https://zbhgis.github.io", "prevUrl": "/index.html", "nextUrl": "disabled"}